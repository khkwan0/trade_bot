generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  isActive      Boolean         @default(true)
  isAdmin       Boolean         @default(false)
  accounts      Account[]
  sessions      Session[]
  telegrams     telegram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}

model exchanges {
  id              Int             @id @default(autoincrement())
  name            String          @db.VarChar(255)
  url             String?         @db.VarChar(255)
  active          Boolean         @default(true)
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @db.Timestamptz(6)
  user_exchanges  user_exchanges[]

  @@unique([name])
}

model pairs {
  id             Int       @id @default(autoincrement())
  user_exchange_id    Int
  user_id        String
  base_currency  String    @db.VarChar(255)
  quote_currency String    @db.VarChar(255)
  active         Boolean   @default(true)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)
  user_exchanges      user_exchanges @relation(fields: [user_exchange_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model preferences {
  id          Int      @id @default(autoincrement())
  user_id     String
  language    String   @default("en") @db.VarChar(255)
  preferences Json     @default("{}")
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)
}

model telegram {
  id         Int      @id @default(autoincrement())
  tg_id      Int
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  prices_ttl Int      @default(300)
  token      String?  @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model networks {
  user_id    String
  network    String   @unique
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model contracts {
  user_id    String
  network    String
  token      String
  address    String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@unique([network, token])
}

model whitelist {
  id         Int      @id @default(autoincrement())
  email      String   @unique 
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model user_exchanges {
  id          Int        @id @default(autoincrement())
  user_id     String
  exchange_id Int
  api_key     String?    @db.VarChar(255)
  api_secret  String?    @db.VarChar(255)
  maker_fee   Float      @default(0.0)
  taker_fee   Float      @default(0.0)
  active      Boolean    @default(true)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  exchange    exchanges  @relation(fields: [exchange_id], references: [id])
  pairs       pairs[]
}
